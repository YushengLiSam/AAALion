# Copy to `server/.env` before running. NEVER commit a real .env.

# --- LLM provider selection ------------------------------------------------
# Pick one of: tokenrouter | anthropic | doubao | openai | echo
# If unset, auto-picks the first provider whose key is available, falling back to "echo".
LLM_PROVIDER=tokenrouter

# --- TokenRouter (aggregator: many models behind one OpenAI-compatible API)
# Get / activate keys at https://www.tokenrouter.com/console/token
# Each AAALion- workspace has a shared 1000-request quota.
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
# TOKENROUTER_API_KEY=...   # set in local server/.env only; NEVER commit
TOKENROUTER_MODEL=claude-sonnet-4-6

# --- Anthropic (current default while Doubao key is being re-issued) -------
# ANTHROPIC_API_KEY is usually inherited from your shell env; only set here if you want to override.
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Doubao (set once the organizer re-distributes the new key) ------------
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
DOUBAO_MODEL_ID=ep-20260514111645-lmgt2
DOUBAO_API_KEY=

# --- OpenAI (optional fallback) --------------------------------------------
# OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_TEXT=products_text
QDRANT_COLLECTION_IMAGE=products_image

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# iOS client points at this base URL (also baked into client/.../Config.swift)
PUBLIC_BACKEND_URL=http://localhost:8000

# Currency normalization for source-currency catalog items (USD, JPY, etc.)
# Frankfurter publishes the latest available reference rate; no API key needed.
FX_API_BASE_URL=https://api.frankfurter.dev/v2
FX_RATE_TTL_SECONDS=3600
FX_HTTP_TIMEOUT_SECONDS=3.0
